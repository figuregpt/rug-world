# Copy this file to .env.local and fill in the values.
# .env.local is gitignored so your private keys stay local.

# === Solana network ===
# Devnet for testing. Switch to mainnet-beta later.
SOLANA_CLUSTER=devnet
SOLANA_RPC=https://api.devnet.solana.com

# === Irys (Arweave bundler) ===
# Devnet Irys node, free for testing but files pin ~60 days.
# Production: https://node1.irys.xyz
IRYS_NODE=https://devnet.irys.xyz

# === Operator wallet (server signer) ===
# Generate with:
#   solana-keygen new --no-bip39-passphrase -o operator.json
# Fund on devnet:
#   solana airdrop 5 -k operator.json --url devnet
# Then paste the JSON array here (cat operator.json output).
OPERATOR_PRIVATE_KEY=[0,0,0, ...]

# Public key of the same operator wallet. Used by the client to set the
# operator as the collection admin during launch (so the server can mint).
# Get it with: solana address -k operator.json
NEXT_PUBLIC_OPERATOR_PUBKEY=

# === Database (Prisma) ===
# SQLite file for dev. Switch to Postgres / Neon / Supabase for production:
#   DATABASE_URL=postgresql://user:pass@host:5432/rugworld
DATABASE_URL="file:./dev.db"
